{
  "expo": {
    "name": "My Barrie Transit Lab",
    "slug": "barrie-transit-planner-detour-lab",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "barrie-transit-lab",
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.barrietransit.planner.detourlab",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "versionCode": 16,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#0c8ce5"
      },
      "package": "com.barrietransit.planner.detourlab",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/app-icon-favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Barrie Transit to use your location to show nearby stops and provide directions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1a73e8",
          "sounds": []
        }
      ],
      "expo-asset",
      "expo-updates",
      "expo-secure-store",
      [
        "./plugins/withLauncherDisplayName",
        {
          "name": "MyBarrie Lab"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "barrie-transit",
          "project": "barrie-transit-planner"
        }
      ],
      "@maplibre/maplibre-react-native",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "7550e65d-8606-4a0b-9fea-e86b646fb573"
      }
    }
  }
}
