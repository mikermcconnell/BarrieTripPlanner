{
  "name": "barrie-transit-planner",
  "version": "1.0.6",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "npm run android:dev",
    "android:direct": "expo run:android",
    "android:recover": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-recover.ps1",
    "android:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-dev.ps1",
    "android:dev:launch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-dev-launch.ps1",
    "android:dev:clear": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-dev.ps1 -ClearMetroCache",
    "android:dev:direct": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-dev.ps1 -Direct",
    "android:dev:proxy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-dev.ps1 -Proxy -Port 8081 -MetroPort 8084",
    "android:stable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-stable.ps1",
    "android:stable:launch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-stable.ps1 -SkipBuild",
    "android:stable:rebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-stable.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "proxy": "node proxy-server.js",
    "web:dev": "concurrently -k -n proxy,expo \"node proxy-server.js\" \"expo start --web\"",
    "fetch-addresses": "node scripts/fetchBarrieAddresses.js",
    "dev:android": "expo start --dev-client",
    "postinstall": "patch-package",
    "test": "npm run test:app",
    "test:app": "jest --runInBand",
    "test:api": "npm --prefix api-proxy test",
    "test:all": "npm run test:app && npm run test:api",
    "test:watch": "jest --watch",
    "check:parity": "node scripts/check-platform-parity.js",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1",
    "build:release:apk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1 -Apk",
    "prebuild:android:production": "node scripts/preflight-android-production-env.js --profile production",
    "eas:build:android": "npm run prebuild:android:eas && eas build --platform android --profile production --clear-cache",
    "eas-build-pre-install": "node scripts/preflight-android-production-env.js",
    "prebuild:android:eas": "eas env:exec production \"node scripts/preflight-android-production-env.js --profile production\" --non-interactive",
    "validate:detour-ground-truth": "node scripts/validate-detour-ground-truth.js",
    "check:detour-scheduler": "node scripts/check-detour-scheduler-health.js"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.4.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@sentry/react-native": "~7.2.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "^14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-updates": "~29.0.17",
    "firebase": "^12.9.0",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.19.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "jest": "~29.7.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "minimatch": "^10.2.3",
    "protobufjs": "^7.5.5",
    "node-forge": "^1.4.0",
    "undici": "^6.24.0",
    "@xmldom/xmldom": "^0.8.13",
    "picomatch": "^4.0.4"
  },
  "private": true
}
