# Copy this file to .env and add your actual API keys

# LocationIQ API key for backend/dev proxy only (never embed in public client builds)
# Get your key at: https://locationiq.com/
LOCATIONIQ_API_KEY=YOUR_LOCATIONIQ_API_KEY_HERE

# API Proxy URL — routes LocationIQ calls through server to hide API key
# For dev: http://localhost:3001 (run `node proxy-server.js`)
# For production: your deployed proxy URL
EXPO_PUBLIC_API_PROXY_URL=http://localhost:3001
# Optional development fallback: allow direct client->LocationIQ calls
# Keep false for production/public builds.
EXPO_PUBLIC_ALLOW_DIRECT_LOCATIONIQ=false
# Optional shared token for non-public/internal clients only.
# This is ignored in production app builds and should stay empty for public releases.
EXPO_PUBLIC_API_PROXY_TOKEN=

# Optional dedicated CORS proxy base used for GTFS web fetches.
# Accepts either a full ".../proxy?url=" value or a base URL ("/proxy?url=" will be appended).
EXPO_PUBLIC_CORS_PROXY_URL=http://localhost:3001/proxy?url=
# Optional shared token sent to private CORS proxy deployments (non-public builds only)
EXPO_PUBLIC_CORS_PROXY_TOKEN=

# Optional: allow public third-party CORS proxy fallbacks on web.
# Default false to avoid unreliable 403/rate-limit behavior.
EXPO_PUBLIC_ENABLE_PUBLIC_CORS_PROXIES=false

# App kill switch for the rider-facing auto detour feature (set true to enable)
EXPO_PUBLIC_ENABLE_AUTO_DETOURS=false
# Legacy fallback for older builds. Prefer EXPO_PUBLIC_ENABLE_AUTO_DETOURS.
EXPO_PUBLIC_ENABLE_DETOUR_GEOMETRY_UI=false
# Local Android scripts start api-proxy's detour worker when auto-detour UI is enabled.
# Set false to keep the emulator scripts from starting the worker.
DETOUR_DEV_WORKER_ENABLED=true

# Enable Transit On-Demand (TOD) zone overlays + trip planner integration
# Default ON (set to 'false' to disable)
EXPO_PUBLIC_ENABLE_TOD_ZONES=true

# Optional OpenTripPlanner backend URL for OTP fallback routing
# Example: https://your-otp.example.com/otp/routers/default
EXPO_PUBLIC_OTP_URL=

# Google Maps API Key
# Get your key from: https://console.cloud.google.com/google/maps-apis
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Sign-In client IDs
# Required for native Google auth. Use the OAuth web client ID at minimum.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID
# Optional platform-specific client IDs if your Google project uses them
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Firebase Configuration
# Get these from: https://console.firebase.google.com/ > Project Settings > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Crash Reporting
# Get your DSN from: https://sentry.io > Project Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Optional path override used by app.config.js for Android Firebase file.
# In EAS, set GOOGLE_SERVICES_JSON as a file secret and this will be auto-resolved.
# GOOGLE_SERVICES_JSON=./google-services.json

# ===============================================
# Backend Detour Worker (api-proxy) Configuration
# ===============================================
# API auth hardening for proxy routes (/api/*)
REQUIRE_API_AUTH=true
# Browser origins allowed to call api-proxy (comma-separated)
# Example: https://app.example.com,https://www.app.example.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
# Use one token or multiple comma-separated tokens
# Keep ALLOW_SHARED_TOKEN_AUTH=false for internet-facing production services.
ALLOW_SHARED_TOKEN_AUTH=false
# API_PROXY_TOKEN=change-me
# API_PROXY_TOKENS=token1,token2
# Firebase ID token auth (recommended for production)
REQUIRE_FIREBASE_AUTH=true
# Optional production survey-admin allowlist. Prefer Firebase custom claims
# (`admin=true` or `surveyAdmin=true`) when possible.
SURVEY_ADMIN_UIDS=
# Firebase Functions only: use `private` in production if callers go through
# an authenticated platform boundary; use `public` only when app-level auth is
# the only available boundary.
API_PROXY_FUNCTION_INVOKER=private

# Enable server-side detour detection worker in api-proxy
DETOUR_WORKER_ENABLED=false
# Enable MyRide transit news sync into Firestore.
# In interval mode, api-proxy polls https://www.myridebarrie.ca/News/GetAllNews every 6 hours.
# In scheduled/manual mode, call POST /api/news-run-once with x-scheduler-token or admin auth.
NEWS_WORKER_ENABLED=false
# Detour worker mode:
# - interval: legacy always-on loop
# - manual: only runs when POST /api/detour-run-once is called
# - scheduled: same single-tick behavior, intended for scheduler triggers
DETOUR_WORKER_MODE=manual
# News worker mode:
# - interval: legacy always-on 6-hour loop
# - manual/scheduled: only runs when POST /api/news-run-once is called
NEWS_WORKER_MODE=scheduled
# Keep false outside a planned baseline-seeding operation. If true, the worker
# may accept live GTFS that already includes an active detour as "normal."
BASELINE_AUTO_INIT=false
# Keep true for validation/production. Blocks detection if only unsafe live
# fallback or auto-initialized baseline data is available.
DETOUR_REQUIRE_SAFE_BASELINE=true
# Route-family handoff can project one branch detour onto a sibling branch (for example 8A/8B).
# Set false during debugging to isolate route assignment issues.
DETOUR_ENABLE_ROUTE_FAMILY_HANDOFF=true
# Enable persistent detour history event logging in Firestore
DETOUR_HISTORY_ENABLED=true
# Retain detour history records for this many days (<=0 disables pruning)
DETOUR_HISTORY_RETENTION_DAYS=30

# Optional tuning (milliseconds / counts)
DETOUR_POLL_INTERVAL_MS=15000
DETOUR_STATIC_REFRESH_MS=21600000
DETOUR_EVIDENCE_WINDOW_MS=1800000
DETOUR_MIN_ROUTE_EVIDENCE=8
DETOUR_MIN_UNIQUE_VEHICLES=2
DETOUR_OFF_ROUTE_THRESHOLD_METERS=75
# Consecutive off-route ticks required before confirming a detour (default 4 = 2 minutes at 30s ticks)
DETOUR_CONSECUTIVE_READINGS=4
# Optional JSON map of route-specific detector tuning.
# Example:
# DETOUR_ROUTE_OVERRIDES_JSON={"8A":{"offRouteThresholdMeters":45,"onRouteClearThresholdMeters":25,"consecutiveReadingsRequired":3,"evidenceWindowMs":2700000},"8B":{"offRouteThresholdMeters":45,"onRouteClearThresholdMeters":25,"consecutiveReadingsRequired":3,"evidenceWindowMs":2700000}}
# Tighter threshold for clearing: vehicle must be within this distance to count as "on-route"
DETOUR_ON_ROUTE_CLEAR_THRESHOLD_METERS=40
# Minimum detour age (ms) before it can enter clear-pending state
DETOUR_CLEAR_GRACE_MS=600000
# Minimum detour age (ms) before clearing is considered at all
DETOUR_MIN_ACTIVE_MS=300000
# Consecutive on-route ticks required per vehicle before clearing.
# If unset, defaults to 6 in interval/manual mode and 4 in scheduled mode.
DETOUR_CLEAR_CONSECUTIVE_ON_ROUTE=6
# Safety-net clear for stale Firestore detours. Uses live route-family vehicles
# plus GTFS headways so low-frequency Sunday routes are not cleared too soon.
DETOUR_STALE_AUTO_CLEAR_ENABLED=true
DETOUR_STALE_AUTO_CLEAR_MIN_MS=2700000
DETOUR_STALE_AUTO_CLEAR_HEADWAY_MULTIPLIER=2
DETOUR_STALE_AUTO_CLEAR_BUFFER_MS=600000
DETOUR_STALE_AUTO_CLEAR_MAX_MS=10800000
DETOUR_STALE_AUTO_CLEAR_DEFAULT_HEADWAY_MS=3600000
# Matching active-detour snapshots required before a long-running detour becomes persistent
DETOUR_PERSIST_CONSECUTIVE_MATCHES=10
# Minimum detour age (ms) before persistence learning is allowed (default 5 hours)
DETOUR_PERSIST_MIN_AGE_MS=18000000
# Geometry write throttle: minimum ms between Firestore geometry writes per route
DETOUR_GEOMETRY_WRITE_THROTTLE_MS=120000
# Optional OSRM-compatible map matching for rider-facing "likely detour path"
DETOUR_ROAD_MATCHING_ENABLED=false
# Example for local validation only. Prefer your own OSRM-compatible service for production.
# DETOUR_ROAD_MATCHING_BASE_URL=https://router.project-osrm.org
DETOUR_ROAD_MATCHING_TIMEOUT_MS=4000
DETOUR_ROAD_MATCHING_MAX_POINTS=100
DETOUR_ROAD_MATCHING_RADIUS_METERS=75
DETOUR_ROAD_MATCHING_ROUTE_FALLBACK_ENABLED=true
# Reject likely detour paths that visibly reuse the closed regular route segment.
DETOUR_ROAD_MATCHING_BLOCKED_PROXIMITY_METERS=15
DETOUR_ROAD_MATCHING_BLOCKED_OVERLAP_RATIO=0.05
DETOUR_ROAD_MATCHING_BLOCKED_ENDPOINT_RATIO=0.12
DETOUR_ROAD_MATCHING_BLOCKED_MIN_POINTS=3
# Strip OSRM route-fallback out-and-back spurs caused by forced waypoints.
DETOUR_ROAD_MATCHING_BACKTRACK_PROXIMITY_METERS=12
DETOUR_ROAD_MATCHING_BACKTRACK_MIN_SEGMENT_METERS=20
DETOUR_ROAD_MATCHING_BACKTRACK_MIN_TURN_DEGREES=150
# Local simulated detours try these offsets until one can be road-matched without reusing the closed segment.
DETOUR_SIMULATION_OFFSET_CANDIDATES_METERS=275,600,1000,1500,1800
# Rollout-health false-positive window (default 7 days)
DETOUR_FALSE_POSITIVE_WINDOW_MS=604800000
# Server-only API key for ops debug endpoint access without Firebase token
# DETOUR_DEBUG_API_KEY=change-me

# Optional key for POST /api/detours/refresh
DETOUR_PROXY_KEY=change-me

# ===============================================
# Optional Local AI (api-proxy)
# ===============================================
# Enable optional local AI enrichments such as survey comment summaries.
LOCAL_AI_ENABLED=false
# Current implementation expects an OpenAI-compatible local HTTP endpoint.
LOCAL_AI_TRANSPORT=http
LOCAL_AI_PROVIDER=geva
LOCAL_AI_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_AI_MODEL=geva-4
LOCAL_AI_TIMEOUT_MS=5000

# Firebase Admin credentials for api-proxy worker writes
# Option A: Inline JSON string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Option B: Path to service account file
# GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json
